---
import Layout from '../../layouts/Layout-rp.astro';
import { ClientRouter } from 'astro:transitions';

const IMG_BASE = "https://raw.githubusercontent.com/Chasel1103/TRPG-Images/main";
const base = import.meta.env.BASE_URL;
---

<Layout>
  <Fragment slot="head">
    <title>Pinot Noir</title>
    <ClientRouter />
  </Fragment>

<div class="outer">

  <!-- 左側：團錄內容 -->
  <div class="log-side">
    <div class="log-top">
      <a href={`${base}/fuukikan`} style="color: rgba(255,255,255,0.3); text-decoration: none; font-size: 13px; letter-spacing: 0.08em; transition: color 0.2s;">⭠ 返回</a>
      <span style="font-size: 13px; color: white;">餐前酒 · Pinot Noir 黑皮諾</span>
    </div>

    <div class="log-content">

      <div class="scene-marker"
        data-bg={`${IMG_BASE}/scene/fuukikan/yoru.webp`}
        data-location="Location"
        data-title={`二號客房・傍晚`}
        data-chars={`泉 夕希`}>
      </div>

    <div class="block-gap"></div>

  <div class="private-wrap" style="--private-color: 188,45,41;">
    
    <div class="private-block">
      <div class="bubble-wrap">
        <div class="title-style">泉的場合</div>
      </div>
    </div>

  </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">比起大廳的奢華感，客房整體所給人的感覺相對低調而舒適。
          <span class="br-sm"></span>
          這間客房的設備遠比一般的商務旅館要好，不僅空間更為寬敞，還附有獨立的浴室。整體的布置並不誇張，卻顯得井然有序，流露出一種舒適感。
          <span class="br-sm"></span>
          房間的一側設有窗戶，上面裝著設計雅緻的格子裝飾。
          <span class="br-sm"></span>
          牆面與地板乾淨整潔，家具規矩實用，既沒有過分奢華的裝飾，也不帶任何花俏的擺設。這是一個單純、普通，卻讓人能安穩歇息的空間。
          <span class="br-sm"></span>
          這裡有一張單人床、床邊小櫃子、衣櫃以及書桌。
        </div>
      </div>
    </div>

    <!-- 泉 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Izumi/normal.webp`} alt="泉" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-izumi">泉 夕希</div>
        <div class="rp-text">泉將背在肩上的包包放到書桌的椅子上，先靠近窗戶、向外看了看。</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">窗外的景色是那片種滿了桔梗花的花海，在月色的照耀下看起來十分美麗。</div>
      </div>
    </div>

    <!-- 擲骰提示 -->
    <div class="dice-block">
      <div class="dice-result">【偵查】</div>
    </div>

    <!-- 擲骰 -->
    <div class="dice-block">
      <div class="dice-name name-izumi">泉 夕希．偵查</div>
      <div class="dice-result">出目 88/65</div>
      <div class="dice-outcome name-fail">失敗</div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">除此之外，你在更遠處的森林裡看見了隱約瀰漫的霧氣。</div>
      </div>
    </div>

    <!-- 泉 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Izumi/947708_uszyDlhK.webp`} alt="泉" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-izumi">泉 夕希</div>
        <div class="rp-text">果然從這個方向望過去也能看見呢。不論看多久都不會膩的美景，泉又多駐足了片刻，然後回到書桌前坐下，拿起手機傳送報平安的訊息。霧氣在太陽出來後就會散了吧，希望明天能好好下山。
          <span class="br-sm"></span>
          突如其來的擔憂沒有煩惱她太久，再次環顧房間，泉打開衣櫃門查看了下。</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">當你想要傳出訊息的時候，卻發現失敗了，似乎是因為沒有訊號的關係。
          <span class="br-sm"></span>
          衣櫃裡什麼都沒有，不過上面的橫桿上掛著幾個衣架。
        </div>
      </div>
    </div>

    <!-- 泉 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Izumi/947708_uszyDlhK.webp`} alt="泉" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-izumi">泉 夕希</div>
        <div class="rp-text">沒有訊號呢？還以為是照片檔案比較大，關上衣櫃回頭一看才發現訊息旁顯示著錯誤符號。不過在來到這裡前是能成功收訊的吧……？這下倒覺得有些困擾，測試了下其他聯絡方式，泉重新背起肩包，拿著手機離開了房間。</div>
      </div>
    </div>

      <div class="scene-marker"
        data-bg={`${IMG_BASE}/scene/fuukikan/yoru.webp`}
        data-location="Location"
        data-title={`三號客房・傍晚`}
        data-chars={`伊萊亞斯．諾德海姆`}>
      </div>

  <div class="private-wrap" style="--private-color: 125, 185, 222;">
    
    <div class="private-block">
      <div class="bubble-wrap">
        <div class="title-style">伊萊亞斯的場合</div>
      </div>
    </div>

  </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">比起大廳的奢華感，客房整體所給人的感覺相對低調而舒適。
          <span class="br-sm"></span>
          這間客房的設備遠比一般的商務旅館要好，不僅空間更為寬敞，還附有獨立的浴室。整體的布置並不誇張，卻顯得井然有序，流露出一種舒適感。
          <span class="br-sm"></span>
          房間的一側設有窗戶，上面裝著設計雅緻的格子裝飾。
          <span class="br-sm"></span>
          牆面與地板乾淨整潔，家具規矩實用，既沒有過分奢華的裝飾，也不帶任何花俏的擺設。這是一個單純、普通，卻讓人能安穩歇息的空間。
          <span class="br-sm"></span>
          這裡有一張單人床、床邊小櫃子、衣櫃以及書桌。
        </div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">伊萊亞斯把身上背的東西放到床邊小櫃子上。</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">希格爾德進到房間後低著頭繞了一圈，尾巴微微搖著。接著，牠走到書桌桌腳前，鼻尖貼著木材嗅了嗅，還伸出舌頭輕舔了一下。
          <span class="br-sm"></span>
          牠的耳朵抖動，像是在聽著房子裡的每一點聲響；偶爾會抬頭盯著床邊的窗簾，頭微微歪向一側。
          <span class="br-sm"></span>
          「汪！」最後，牠走回床邊，鼻尖推了推伊萊亞斯的手，尾巴輕快地晃動著。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">「Flink gutt.（好孩子。）」他笑著拍了拍希格爾德的頭。伊萊亞斯從背包裡摸出一小包零食，拆開包裝的聲音讓希格爾德的尾巴晃得更歡快了。</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">眼神閃亮亮的看著主人拆零食包裝。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">他捏了一小塊零食放在掌心，伸到希格爾德面前，「Vent.（等。）」</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">希格爾德乖乖坐在床邊，嘴巴微微張開，垂著舌哈氣著。牠的眼睛一眨不眨地盯著主人手裡的小零食，尾巴忍不住拍打著房間地板。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">「Vær så god.（可以了。）」伊萊亞斯將零食放在地上。</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">希格爾德立刻叼起了小零食，「喀啦、喀啦」地幾聲咀嚼後，希格爾德舔了舔嘴，「汪！」又湊近用鼻子頂了頂伊萊亞斯的掌心，尾巴搖的更快了。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">伊萊亞斯蹲了下來慢慢地撫摸著希格爾德的頭頂，「Det går bra, Sig.（沒事的，Sig。）」隨後才回應了鳥取，「……這裡路不對，不知道是哪裡。」</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP ➤ <span class="name-elias">伊萊<span></div>
        <div class="rp-text">伊萊亞斯拍了拍希格爾德的頭頂，伸手揉亂了牠的耳朵。
          <span class="br-sm"></span>
          人這才站起來看看房間有沒有什麼特別的。</div>
      </div>
    </div>

    <!-- 擲骰提示 -->
    <div class="dice-block">
      <div class="dice-result">【偵查】</div>
    </div>

    <!-- 擲骰 -->
    <div class="dice-block">
      <div class="dice-name name-elias">伊萊亞斯．偵查</div>
      <div class="dice-result">出目 93/58</div>
      <div class="dice-outcome name-fail">失敗</div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">這裡看起來似乎沒什麼特別的，就是整理得很乾淨的客房。
        </div>
      </div>
    </div>

    <!-- 擲骰 -->
    <div class="dice-block">
      <div class="dice-name">希格爾德．嗅覺</div>
      <div class="dice-result">出目 54/90</div>
      <div class="dice-outcome name-success">成功</div>
    </div>

  <div class="private-wrap" style="--private-color: 255, 255, 255;">
    
    <div class="private-block">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP ➤ 希格爾德</div>
        <div class="rp-text">希格似乎嗅到了什麼味道，不同於家具和木頭的材質，更像是來自於什麼人的，從衣櫃裡散發出來。
        </div>
      </div>
    </div>

  </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">牽起希格爾德的牽繩，打算去洋館外面散散步。</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">當你來到洋館外面的時候，道路兩側的桔梗花依舊隨風在輕輕搖曳著，微風徐拂而來，遠處的森林裡可以看見有霧氣瀰漫在其中。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">牽著希格爾德在洋館附近閒晃著，霧氣比他想的還要更大更濃些，讓他的腳步始終沒有離建築太遠。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">雖然正值夏季，但是山區入了夜後氣溫仍舊偏低，雖然不管是他還是希格爾德都不覺得這算得上寒冷。不過今天已經幾乎一整天都在戶外，希爾格爾德看上去也對那些本來興致滿滿的桔梗花叢失去了興趣。
        <span class="br-sm"></span>
        他拉了拉牽繩，帶著希格爾德回到的建築內，決定去接待室看看。</div>
      </div>
    </div>

<hr class="custom-divider" />

      <div class="scene-marker"
        data-bg={`${IMG_BASE}/scene/fuukikan/hanabatake.webp`}
        data-location="Location"
        data-title={`接待室・傍晚`}
        data-chars={`泉 夕希\n伊萊亞斯．諾德海姆`}>
      </div>

    <!-- 泉 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Izumi/normal.webp`} alt="泉" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-izumi">泉 夕希</div>
        <div class="rp-text">簡訊發送不出去，電話也撥不通，泉舉著手機走下樓梯、經過大廳，走出了門外。哎呀，這下該怎麼辦？向外走了一段距離，她在小徑邊蹲下，盯著桔梗花思考，但眼下似乎沒有任何辦法。也不是我不願意聯繫……希望那孩子不要太擔心呢。忍不住去思考未能連通的手機另一邊的人會是什麼心情，好像不太妙的感覺油然而生。有西條小姐在應該沒問題吧……？這麼做了結論，收起手機後又看著桔梗花發呆了會兒，她才慢慢地站起身往室內回去。</div>
      </div>
    </div>
  
    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.webp`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">當泉回到大廳後，正因為沒辦法向外聯絡而有些煩惱的你聽見了來自身後的吠聲。</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">希格爾德很熱情的朝泉靠近。</div>
      </div>
    </div>

    <!-- 伊萊 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/normal.webp`} alt="伊萊" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-elias">伊萊亞斯．諾德海姆</div>
        <div class="rp-text">他點了點頭，「牠喜歡你。慢一點，別嚇到牠。」語調慢悠悠的。</div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.webp`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname">希格爾德</div>
        <div class="rp-text">希格爾德尾巴輕快地搖著，耳朵也豎了起來。</div>
      </div>
    </div>

    <!-- 泉 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Izumi/normal.webp`} alt="泉" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-izumi">泉 夕希</div>
