<script>
  // 使用 astro:page-load 確保在 ClientRouter 切換頁面後仍能執行
  document.addEventListener('astro:page-load', () => {
    // 1. 取得右側顯示面板的元素，並斷言為 HTMLElement 以解決 style 報錯
    const sceneBg = document.querySelector('.scene-bg') as HTMLElement | null;
    const sceneTitle = document.querySelector('.scene-title') as HTMLElement | null;
    const sceneLocation = document.querySelector('.scene-location') as HTMLElement | null;
    const sceneChars = document.querySelector('.scene-chars') as HTMLElement | null;
    const verticalTitle = document.querySelector('.vertical-title') as HTMLElement | null;

    // 2. 取得滾動容器與所有埋點
    const logContent = document.querySelector('.log-content') as HTMLElement | null;
    const markers = document.querySelectorAll('.scene-marker');

    if (!logContent || markers.length === 0) return;

    // 3. 預載圖片邏輯
    markers.forEach(marker => {
      const m = marker as HTMLElement;
      if (m.dataset.bg) {
        const img = new Image();
        img.src = m.dataset.bg;
      }
    });

    // 4. 定義更新內容的函數
    const updateScene = (marker: HTMLElement) => {
      console.log("偵測到場景切換:", marker.dataset.bg); // 打開 F12 看看有沒有跑這行
      const { bg, title, location, chars } = marker.dataset;

      if (bg && sceneBg) {
        sceneBg.style.backgroundImage = `url('${bg}')`;
      }
      if (title && sceneTitle) {
        sceneTitle.innerHTML = title.replace(/\n/g, '<br>');
        // 同步更新側邊直排文字 (取標題第一行)
        if (verticalTitle) verticalTitle.innerText = title.split('\n')[0];
      }
      if (location && sceneLocation) {
        sceneLocation.textContent = location;
      }
      if (chars && sceneChars) {
        sceneChars.innerHTML = chars.replace(/\n/g, '<br>');
      }
    };

    // 5. 設定觀察器
    const observerOptions = {
      root: logContent,
      // rootMargin 決定觸發位置：這裡設定在畫面中偏上的位置 (-20% 頂部, -70% 底部)
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          updateScene(entry.target as HTMLElement);
        }
      });
    }, {
      root: logContent,
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    });

    logContent.addEventListener('scroll', () => {
      const containerMid = logContent.scrollTop + logContent.clientHeight * 0.3;
      
      let currentMarker: HTMLElement | null = null;
      markers.forEach(marker => {
        const m = marker as HTMLElement;
        if (m.offsetTop <= containerMid) {
          currentMarker = m;
        }
      });
      
      if (currentMarker) updateScene(currentMarker);
    });

    // 6. 開始觀察每個埋點
    markers.forEach(marker => observer.observe(marker));

    // 7. 初始化：預設顯示第一個埋點的內容
    updateScene(markers[0] as HTMLElement);
  });
</script>