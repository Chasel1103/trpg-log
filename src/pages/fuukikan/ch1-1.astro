---
  const IMG_BASE = "https://raw.githubusercontent.com/Chasel1103/TRPG-Images/main";

  const base = import.meta.env.BASE_URL;
---
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Beaujolais</title>
</head>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    overflow: hidden;
    background: #1a1a24;
    font-family: sans-serif;
    color: white;
  }

  .outer {
    width: 100%;
    height: 100vh;
    display: flex;
    overflow: hidden;
  }

  /* ==============================
     左側：團錄內容
  ============================== */
  .log-side {
    width: 70%;
    background: #0d0d0f;
    box-shadow: 6px 0 32px rgba(0,0,0,0.8);
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    overflow: hidden; /* 改掉原本的overflow-y: scroll */
    scrollbar-width: none;
  }
  .log-side::-webkit-scrollbar { display: none; }

  .log-top {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    padding: 1.2rem 2rem 1.2rem 2.5rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
    flex-shrink: 0; /* 不會被壓縮 */
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .log-content {
  flex: 1;
  overflow-y: scroll;
  scrollbar-width: none;
  padding: 2rem 2rem 2.5rem 2.5rem;
  }
  .log-content::-webkit-scrollbar { display: none; }

  /* RP行：橫向排列頭像+內容 */
  .row {
    display: flex;
    gap: 12px;
    margin-bottom: 3.5rem;
    align-items: flex-start;
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 5px;
    background: rgba(255,255,255,0.06);
    border: 0.5px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
    object-fit: cover;
    object-position: top center;
  }
  .avatar.ghost { opacity: 0; pointer-events: none; }

  .bubble-wrap {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 85%;
  }

  .charname {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
    padding: 0 2px;
    color: rgba(255,255,255,0.6);
  }

  /* RP文字：無對話框，動作台詞不分段 */
  .rp-text {
    font-size: 15px;
    line-height: 1.85;
    color: rgba(255,255,255,0.72);
    padding: 2px 2px 8px;
  }

  /* 擲骰區塊 */
  .dice-block {
    margin: 1.8rem auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    width: 100%;
    flex-shrink: 0;
  }
  .dice-name {
    font-size: 12.5px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.06em;
  }
  .dice-result {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.08em;
    margin-top: 2px;
  }
  .dice-outcome {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.12em;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }
  .dice-outcome::before,
  .dice-outcome::after {
    content: '';
    display: block;
    width: 40px;
    height: 0.5px;
    background: rgba(255,255,255,0.2);
  }

  .block-gap { margin-bottom: 1.2rem; flex-shrink: 0; }

  /* 角色名顏色 */
  .name-white { color: #ffffff; }
  .name-sage  { color: #8db8a0; }
  .name-navy  { color: #6b8cba; }
  .name-kp    { color: rgba(255,255,255,0.38); }
  .name-saijo  { color: #749F8D; }  /* 西條 */
  .name-izumi  { color: #BC2D29; }  /* 泉 */
  .name-elias  { color: #7DB9DE; }  /* 伊萊 */
  .name-chiyuki  { color: #FBFBF6; }  /* 鳥取 */
  .name-success  { color: #2EA9DF; }
  .name-fail     { color: #D0104C; }

  .private-block {
    width: 65%;
    margin: 1.8rem auto;
    background: rgba(255, 255, 255, 0.05);
    padding: 1.2rem 1.5rem;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .private-block .avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .private-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .private-block {
    background: rgba(var(--private-color), 0.3);
    border-color: rgba(var(--private-color), 0.4);
  }
  .private-block::before,
  .private-block::after {
    background: rgba(var(--private-color), 0.4);
  }

  .br-sm {
    display: block;
    margin-bottom: 0.4rem;
  }

  /* ==============================
     右側：場景資訊（固定不滾動）
  ============================== */
  .scene-side {
    width: 30%;
    height: 100vh;
    position: relative;
    background: #2a2535;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  /* 背景圖片層 */
  .scene-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #1e1a2e;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 1;
    transition: background-image 0.8s ease-in-out;
  }

  .scene-deco { position: absolute; inset: 0; z-index: 1;}
  .scene-deco-line1 { position: absolute; top: 18%; left: 0; right: 0; height: 0.5px; background: rgba(255,255,255,0.07); }
  .scene-deco-line2 { position: absolute; top: 22%; left: 20%; right: 0; height: 0.5px; background: rgba(255,255,255,0.04); }
  .scene-deco-circle { position: absolute; top: 10%; right: 15%; width: 80px; height: 80px; border-radius: 50%; border: 0.5px solid rgba(255,255,255,0.06); }
  .scene-deco-rect { position: absolute; bottom: 30%; left: 10%; width: 40px; height: 40px; border: 0.5px solid rgba(255,255,255,0.05); transform: rotate(20deg); }

  .vertical-title {
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-family: serif;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.7);
    white-space: nowrap;
    line-height: 1;
    padding: 1rem 0;
  }

  /* ==============================
    通往下一頁
  ============================== */
  .next-chapter {
    position: sticky;
    bottom: 2rem;
    display: flex;
    justify-content: flex-end;
    padding-right: 2rem;
    margin-top: 2rem;
    flex-shrink: 0;
  }

  .next-chapter a {
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.7);
    border: 0.5px solid rgba(255,255,255,0.3);
    padding: 10px 20px;
    transition: color 0.2s, border-color 0.2s;
  }

  .next-chapter a:hover {
    color: white;
    border-color: rgba(255,255,255,0.7);
  }

  .scene-info { position: relative; z-index: 2; }
  .scene-location { font-size: 15px; letter-spacing: 0.1em; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 0.6rem; }
  .scene-title { font-size: 20px; font-weight: 500; color: rgba(255,255,255,0.75); margin-bottom: 1rem; line-height: 1.4; }
  .scene-chars-label { font-size: 15px; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); text-transform: uppercase; margin-bottom: 0.4rem; }
  .scene-chars { font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.8; }
</style>

<body>
<div class="outer">

  <!-- 左側：團錄內容 -->
  <div class="log-side">
    <div class="log-top">
      <a href={`${base}/fuukikan`} style="color: rgba(255,255,255,0.3); text-decoration: none; font-size: 13px; letter-spacing: 0.08em; transition: color 0.2s;">⭠ 返回</a>
      <span style="font-size: 13px; color: white;">餐前酒 · Beaujolais 博若萊</span>
    </div>

    <div class="log-content">

      <div class="scene-marker"
        data-bg={`${IMG_BASE}/scene/Keiji/office.jpg`}
        data-location="Location"
        data-title={`某座山(?)・傍晚`}
        data-chars={`西條 遙香\n泉 夕希\n伊萊亞斯．諾德海姆\n■■ ■■`}>
      </div>
    <!-- KP：右側 -->
    <div class="dice-block">
      <div class="dice-result">クトゥルフ神話TRPG【桔梗館的某夜】<br></div>
      <br><br>
      <div class="dice-result">第一話</div>
    </div>

    <div class="block-gap"></div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/goldfish.png`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP</div>
        <div class="rp-text">此時正值傍晚時分，在夕霞山待了一整天的你們正往山下的方向離開。<br><span class="br-sm"></span>
          然而周遭不知何時開始便飄起霧氣，明明前方的山道應該只有一條而已，但不管怎麼走都遲遲未見盡頭。<br><span class="br-sm"></span>
          這是在山林裡迷路了嗎？<br><span class="br-sm"></span>
          霧氣始終未曾散去，在這條山路上你們也只能看到彼此，附近似乎沒有其他遊客了。<br><br>
        </div>
      </div>
    </div>

    <!-- 希格爾德 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Elias/sig.png`} alt="Sig" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">希格爾德</div>
        <div class="rp-text">放慢了步伐，嗅了嗅地面。</div>
      </div>
    </div>

    <div class="private-block" style="--private-color: 150,150,150;">
      <img src={`${IMG_BASE}/KPs/goldfish.png`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP → 希格爾德</div>
        <div class="rp-text">儘管你已經來過夕霞山許多次了，然而這附近的氣息對你來說有些陌生。</div>
      </div>
    </div>

    <!-- 鳥取 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/chiyuki/normal.png`} alt="chiyuki" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-chiyuki">鳥取 千之</div>
        <div class="rp-text">少年舉起手機，在山路中央又照了張相、拍下了不知第幾條街景後，開始和前面的幾張相片對比。<br>
準備下山時，天色尚顯清亮，相片就這樣一路從艷陽高照到天幕昏黃，放眼望去，漸層色的相簿像是某種藝術性的紀錄，只有他自己知道，這大半都只是為了尋路。<br>
<span class="br-sm"></span>
直到被霧幕壟罩的最後一張相片已經看不出與來路的相似之處、彷彿是在為他被打亂的計畫開脫似的，手機電量就此告捷，畫面一下暗了下去。<br>
<span class="br-sm"></span>
鳥取沉默了半晌，轉頭朝走在附近的幾人有些不好意思地笑笑：「……那個、不好意思，請問你們的手機有地圖嗎？我好像有點迷路了。」</div>
      </div>
    </div>

    <!-- 砂金 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Isago/normal.png`} alt="砂金 理來" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">砂金 理來</div>
        <div class="rp-text">「……。」轉頭收拾起包。</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">一如你的預想，那人砰一聲推開你們辦公室的門，似乎毫不意外地無視了空蕩蕩的辦公室，直接轉向你。</div>
      </div>
    </div>

    <!-- 刑事：右側NPC -->
    <div class="row">
      <div class="avatar">刑</div>
      <div class="bubble-wrap">
        <div class="charname name-kp">刑事</div>
        <div class="rp-text">「你就是砂金吧？我聽說你們課今天就只有你回來了。」<br>「我們這有個待審訊的犯人，你過來支援一下。」</div>
      </div>
    </div>

    <!-- 砂金 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Isago/normal.png`} alt="砂金 理來" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">砂金 理來</div>
        <div class="rp-text">「哎呀、這還真是不湊巧。」<br>「我還得給我的同事們收拾下呢，今天常態性的工作因為課上的意外一點都沒動彈，而且島田警部不是大名鼎鼎的刑事一課嗎？那邊的工作我可幫不上什麼忙吶。」</div>
      </div>
    </div>


    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">在聽見你熟練喊出他的姓氏和職銜時，那人眉頭一挑，但最終還是沒有理會你的推託，反而皺起眉頭準備轉身。</div>
      </div>
    </div>

    <!-- 刑事 -->
    <div class="row">
      <div class="avatar">刑</div>
      <div class="bubble-wrap">
        <div class="charname name-kp">刑事</div>
        <div class="rp-text">「那從現在開始，這個就是K課的日常工作項目之一，我領你上去。」</div>
      </div>
    </div>

    <!-- 砂金 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Isago/normal.png`} alt="砂金 理來" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">砂金 理來</div>
        <div class="rp-text">「一課真是我行我素呢？」他微微一笑，轉過椅子起身跟上對方。</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">路上，島田向你解說起確切的工作內容：這次要審訊的是今天凌晨因涉嫌搶劫被捕的嫌疑人。<br>雖說逮捕時似乎就審訊過一次，但慎重起見，上層決定再審訊一次。因為人手不足，聽聞K課還剩個人有回課上，便臨時將你叫了過來。<br>儘管島田臉上的不信任溢於言表，但還是公事公辦地向你介紹起犯人與案件的情報。</div>
      </div>
    </div>

    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">嫌疑人名為清水 祟（Shimizu Tatari）。<br>對其犯罪事實供認不諱。過去曾因搶劫罪被判處實刑。<br>今天凌晨2點，嫌疑人潛入了某位收藏家的住宅實施盜竊，在被數名保安發現後抓獲。<br>期間，嫌疑人用小刀刺傷一名保安並企圖逃跑，但未能成功。警方隨後接到報案，前來現場接管了嫌疑人。檢查室內財物損失情況時，發現收藏家丟失了一本藏書。<br>根據收藏家的證詞，可以確認那是一本價值極高的《死靈之書》抄本。<br>嫌疑人並未攜帶贓物，警方目前正在追查藏書下落。另外，嫌疑人被捕時，隨身物品只有小刀、應急安全槌和手機。</div>
      </div>
    </div>

      <div class="scene-marker"
        data-bg={`${IMG_BASE}/scene/Keiji/mansion.jpg`}
        data-location="Location"
        data-title={`審訊室・傍晚`}
        data-chars={`砂金 理來`}>
      </div>

    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">說著，你們也來到了審訊室門口。 推開門後，映入眼簾的是一間擺放著樸素桌椅的白色房間。桌椅對側，一名身材高大的男子打量著進門的你。島田向你介紹，這位就是剛剛討論的清水祟。此外，他一旁還坐著一名負責記錄審訊過程的刑警。</div>
      </div>
    </div>

    <!-- 砂金 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Isago/normal.png`} alt="砂金 理來" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">砂金 理來</div>
        <div class="rp-text">「你好呀。」見島田快步離開，他朝嫌疑人揚起手，像是見到舊識般笑著拉開了剩餘的椅子坐下。<br><br>「說起來，其實我沒有做過審訊工作呢，初次見面，還請您多海涵吶。」</div>
      </div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
        <div class="rp-text">你看到記錄員露出了無奈的表情。<br>清水則是面不改色地看著你，開口道：「無所謂，無論誰來審訊，我的答案都是一樣的。」</div>
      </div>
    </div>

    <!-- 砂金 -->
    <div class="row">
      <img src={`${IMG_BASE}/Characters/Isago/normal.png`} alt="砂金 理來" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-isago">砂金 理來</div>
        <div class="rp-text">「這樣啊、那就好辦了。」他一隻手撐在桌上、輕輕托住臉頰，另一隻手隨意擺在桌面、掌心朝上，一副放鬆的姿態朝清水瞇起眼睛笑道。<br><br>「我們速戰速決吧？清水先生只需要把想說的話都說出來就好了喔。」</div>
      </div>
    </div>

    <!-- 擲骰提示 -->
    <div class="dice-block">
      <div class="dice-result">《魅惑》</div>
    </div>

    <!-- 擲骰 -->
    <div class="dice-block">
      <div class="dice-name name-isago">砂金 理來．魅惑</div>
      <div class="dice-result">出目 5/15</div>
      <div class="dice-outcome name-success">困難成功</div>
    </div>

    <!-- KP -->
    <div class="row">
      <img src={`${IMG_BASE}/KPs/obake1.PNG`} alt="kp" class="avatar" />
      <div class="bubble-wrap">
        <div class="charname name-kp">KP(?)</div>
