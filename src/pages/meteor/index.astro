---
import { ClientRouter } from 'astro:transitions';
import Layout from '../../layouts/Layout.astro';
 
const IMG_BASE = "https://raw.githubusercontent.com/Chasel1103/TRPG-Images/main";
const base = import.meta.env.BASE_URL;

const script = {
  title: '刑事 I 的報告',
  info: {
    人數: '1人',
    形式: 'KPless',
    LOST率: '低',
  },
  tags: ['#KPless', '#一本道'],
  isBright: true,
  summary: `2月27日，凌晨2點。
警方接獲報案，當地著名的某位收藏家家中有一本書遭竊，且一名警衛被刀刺傷。
幸好警衛僅受輕傷。經查證發現，嫌犯男子過去曾有強盜罪的入獄判決紀錄。

2月27日，下午。
身為刑事警察的探索者，將對這名被指認為犯人的男子進行審訊。`,
  image: `${IMG_BASE}/scene/cover/keiji.webp`,
  vtName: 'card-keiji',
  pcs: [
    {
      name: '砂金 理來',
      color: '#ff5255',
      avatar: '/avatars/tougi.webp',
      bio: `K縣警K課 HO1
先打點東西`,
    },
  ],
};
---

<Layout>
  <Fragment slot="head">
    <title>{script.title}</title>
    <ClientRouter />
  </Fragment>

  <section class="hero-section">

    <header class="info-bar">
      <a class="info-bar__back" href={`${base}/`}>← 返回目錄</a>
      <div class="info-bar__divider"></div>
      {Object.entries(script.info).map(([key, val]) => (
        <div class="info-bar__item">{key}<span>{val}</span></div>
      ))}
      <div class="info-bar__tags">
        {script.tags.map(tag => (
          <span class="info-bar__tag">{tag}</span>
        ))}
      </div>
    </header>

    <div class="main-body">

      <div class={`main-body__image ${script.isBright ? 'is-bright' : ''}`} style={`--vt-name-var: ${script.vtName}`}>
        {script.image ? (
          <img src={script.image} alt={script.title} />
        ) : (
          <div class="main-body__image-placeholder"></div>
        )}
      </div>

      <div class="main-body__content">

        <div class="tab-container">
          <div class="tab-track" id="tabTrack">

            <div class="tab-page">
              <div class="summary__title">{script.title}</div>
              <div class="summary__text">{script.summary}</div>
            </div>

            <div class="tab-page">
              <div class="pc-list">
                {script.pcs.map(pc => (
                  <div class="pc-item">
                    <div class="pc-item__avatar-placeholder">
                      <img
                        src={`${IMG_BASE}/Characters/Isago/normal.png`}
                        alt={pc.name}
                        style="width: 100%; height: 100%; object-fit: cover;"
                      />
                    </div>
                    <div>
                      <div
                        class="pc-item__name"
                        style={{ color: pc.color }}
                      >
                        {pc.name}
                      </div>
                      <div class="pc-item__bio">{pc.bio}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>

        <div class="tab-switcher">
          <button class="tab-btn active" id="btnSummary">劇本介紹</button>
          <button class="tab-btn" id="btnPc">登場PC</button>
        </div>

      </div>
    </div>

  </section>

  <section class="custom-catalog-section" id="story-catalog">
    <h2 class="catalog-title">LOGS / CHAPTERS</h2>
    <div class="custom-content">
      <p style="text-align:center; color:rgba(255,255,255,0.3); font-size: 12px;">
        ── 此處可根據劇本章節進行客製化設計 ──
        <br>
        <a href={`${base}/keiji/ch1`}>第一章「Q」</a><br>
        <a href={`${base}/keiji/ch2`}>第二章「E」</a><br>
        <a href={`${base}/keiji/ch3`}>幕間「D」</a><br>
        <a href={`${base}/keiji/ch4`}>第三章「.」</a><br>
      </p>
    </div>
  </section>

</Layout>

<style>
  body {
    min-height: 100vh;
    display: block;
  }

  .hero-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .custom-catalog-section {
    min-height: 100vh;
    padding: 4rem 3rem;
    background: #0d0b16;
  }

  .catalog-title {
    font-family: serif;
    font-size: 24px;
    -webkit-text-stroke: 0.5px rgba(255,255,255,0.6);
    margin-bottom: 2rem;
    letter-spacing: 0.2em;
    text-align: center;
  }

  .info-bar {
    flex: 0 0 10vh;
    display: flex;
    align-items: center;
    padding: 0 3rem;
    gap: 3rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.08);
  }

  .info-bar__back {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .info-bar__back:hover { color: rgba(255,255,255,0.7); }

  .info-bar__divider {
    width: 0.5px;
    height: 1.2rem;
    background: rgba(255,255,255,0.12);
    flex-shrink: 0;
  }

  .info-bar__item {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .info-bar__item span {
    color: rgba(255,255,255,0.7);
    margin-left: 0.5rem;
  }

  .info-bar__tags {
    display: flex;
    gap: 1rem;
    margin-left: auto;
  }

  .info-bar__tag {
    font-size: 13px;
    color: rgba(255,255,255,0.28);
    letter-spacing: 0.04em;
  }

  .main-body {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .main-body__image {
    position: relative;
    overflow: hidden;
    view-transition-name: var(--vt-name-var);
  }

  .main-body__image.is-bright::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
    pointer-events: none;
    transition: background 0.3s;
  }

  .main-body__image img {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .main-body__image-placeholder {
    width: 100%;
    height: 100%;
    background: #100e1a;
    border-right: 0.5px solid rgba(255,255,255,0.06);
  }

  .main-body__content {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .tab-container {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .tab-track {
    display: flex;
    width: 200%;
    height: 100%;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tab-track.show-pc {
    transform: translateX(-50%);
  }

  .tab-page {
    width: 50%;
    height: 100%;
    overflow-y: auto;
    padding: 3rem 3rem 2rem;
    flex-shrink: 0;
  }

  .summary__title {
    font-family: 'Chen';
    font-size: 35px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.12em;
    margin-bottom: 2rem;
    text-align: center;
  }

  .summary__text {
    font-size: 14px;
    line-height: 2;
    color: rgba(255,255,255,0.65);
    text-align: center;
    white-space: pre-line;
  }

  .pc-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pc-item {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 1rem;
    align-items: start;
  }

  .pc-item__avatar-placeholder {
    width: 140px;
    height: 140px;
    background: #1a1828;
    border: 0.5px solid rgba(255,255,255,0.1);
  }

  .pc-item__name {
    font-size: 20px;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }

  .pc-item__bio {
    font-size: 13px;
    line-height: 1.8;
    color: rgba(255,255,255,0.45);
  }

  .tab-switcher {
    flex-shrink: 0;
    padding: 1rem 3rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-top: 0.5px solid rgba(255,255,255,0.06);
  }

  .tab-btn {
    font-size: 13px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
    background: none;
    border: 0.5px solid rgba(255,255,255,0.12);
    padding: 6px 16px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .tab-btn:hover {
    color: rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.3);
  }
  .tab-btn.active {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.4);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const track = document.getElementById('tabTrack');
    const btnSummary = document.getElementById('btnSummary');
    const btnPc = document.getElementById('btnPc');

    if (btnSummary && btnPc && track) {
      btnSummary.addEventListener('click', () => {
        track.classList.remove('show-pc');
        btnSummary.classList.add('active');
        btnPc.classList.remove('active');
      });

      btnPc.addEventListener('click', () => {
        track.classList.add('show-pc');
        btnPc.classList.add('active');
        btnSummary.classList.remove('active');
      });
    }
  });
</script>