---
import Layout from '../layouts/Layout.astro';
import { ClientRouter } from 'astro:transitions';

const IMG_BASE = "https://raw.githubusercontent.com/Chasel1103/TRPG-Images/main";
const base = import.meta.env.BASE_URL;
---
<Layout>
  <Fragment slot="head">
    <title>偷偷說桌團錄合集</title>
    <ClientRouter />
  </Fragment>

<Layout>

  <section id="cover">
    <div class="carousel">
      <div class="carousel__slide active">
      <!-- 沼男は誰だ -->
      
        <div class="cover__bg" style={`background-image: url('${IMG_BASE}/scene/cover/swampman.webp')`}></div>
        <div class="cover__bg-deco"></div>
        <div class="cover__title-wrap">
          <div class="cover__title-line cover__title-line--top">沼男は</div>
          <div class="cover__title-line cover__title-line--bottom">誰だ？</div>
        </div>
        <div class="cover__card">
          <div class="cover__info">
            <div class="cover__info-row">人數　4人<br>時長　中<br>撕卡率　高</div>
            <div class="cover__info-tags">#哲學　#半開放探索　#說啥我才不劇透勒</div>
          </div>
          <div class="cover__cast">
            <div class="cover__cast-label">Cast</div>
            <div class="cover__cast-names">西條 遙香<br>泉 夕希<br>笹島 大地<br>葛城 弘樹</div>
          </div>
        </div>
      </div>

      <!-- K縣警K課 -->
      <div class="carousel__slide">
        <div class="cover__bg" style={`background-image: url('${IMG_BASE}/scene/cover/K.webp')`}></div>
        <div class="cover__bg-deco"></div>
        <div class="cover__title-wrap">
          <div class="cover__title-line cover__title-line--top">K県警</div>
          <div class="cover__title-line cover__title-line--bottom">K課</div>
        </div>
        <div class="cover__card">
          <div class="cover__info">
            <div class="cover__info-row">人數　4人<br>時長　五部曲<br>撕卡率　??</div>
            <div class="cover__info-tags">#4HO　#無法、外道、不道德！？</div>
          </div>
          <div class="cover__cast">
            <div class="cover__cast-label">Cast</div>
            <div class="cover__cast-names">砂金 理來<br>久世 真宵<br>龍守 蓮司<br>灰野 悠仁</div>
          </div>
        </div>
      </div>

      <!-- 豪華客船怪盜團 -->
      <div class="carousel__slide">
        <div class="cover__bg" style={`background-image: url('${IMG_BASE}/scene/cover/phantom-thief.webp')`}></div>
        <div class="cover__bg-deco"></div>
        <div class="cover__title-wrap">
          <div class="cover__title-line cover__title-line--top">豪華客船</div>
          <div class="cover__title-line cover__title-line--bottom">怪盜團</div>
        </div>
        <div class="cover__card">
          <div class="cover__info">
            <div class="cover__info-row">人數　4人<br>時長　短<br>撕卡率　高</div>
            <div class="cover__info-tags">#TAG下啥好　#還沒有想法捏</div>
          </div>
          <div class="cover__cast">
            <div class="cover__cast-label">Cast</div>
            <div class="cover__cast-names">冨永 宝<br>歌代 遙<br>青山 幸助<br>七夕 七星</div>
          </div>
        </div>
      </div>
      
      </div>
    </div>

    <!-- 左右箭頭 + 指示點 -->
    <div class="carousel__controls">
      <button class="carousel__prev" aria-label="上一張">&#9664;</button>
      <div class="carousel__dots">
        <span class="carousel__dot active"></span>
        <span class="carousel__dot"></span>
      </div>
      <button class="carousel__next" aria-label="下一張">&#9654;</button>
    </div>

    <a class="cover__scroll-btn" href="#catalog" aria-label="前往目錄">
      <span class="cover__scroll-label">Scroll</span>
      <span class="cover__scroll-arrow"></span>
    </a>
  </section>

  <section id="catalog">

    <!-- 刑事I的報告keiji -->
    <div class="entry">
